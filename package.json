{
  "name": "starchild-orderly-plugin",
  "version": "1.0.1",
  "description": "Embed Starchild AI assistant into your Orderly DEX — chat with AI to query your Orderly account positions and orders.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup && tailwindcss -i ./tailwind.css -o ./dist/styles.css",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "orderly",
    "plugin",
    "ai",
    "assistant",
    "trading",
    "dex"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@orderly.network/hooks": ">=2.10.1",
    "@orderly.network/i18n": ">=2.10.1",
    "@orderly.network/plugin-core": ">=2.10.1",
    "@orderly.network/ui": ">=2.10.1",
    "react": ">=18",
    "react-dom": ">=18",
    "zustand": ">=4.5.0"
  },
  "devDependencies": {
    "@orderly.network/i18n": "^3.1.2",
    "@orderly.network/plugin-core": "^3.1.2",
    "@orderly.network/ui": "^3.1.2",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "react": "^18",
    "react-dom": "^18",
    "tailwindcss": "^3.4.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "zustand": "^4.5.0"
  }
}
